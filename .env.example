NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sms_api

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_COMMAND_TIMEOUT_MS=2000

JWT_SECRET=replace_with_32_plus_chars_secret_value
JWT_PREVIOUS_SECRET=
JWT_ISSUER=sms-sending-api
JWT_AUDIENCE=sms-saas-clients
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

API_KEY_HASH_SECRET=replace_with_32_plus_chars_secret_value
API_KEY_PREFIX=sms_test_

WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
WEBHOOK_NONCE_TTL_SECONDS=600

SMS_PROVIDER=mock

CLICK_MERCHANT_ID=demo_click_merchant
CLICK_SECRET_KEY=demo_click_secret
PAYME_MERCHANT_ID=demo_payme_merchant
PAYME_SECRET_KEY=demo_payme_secret
PAYMENT_RETURN_URL=https://example.com/payments/return

GLOBAL_RATE_LIMIT_RPM=1200
TENANT_DAILY_SPEND_LIMIT=500
PROVIDER_DAILY_QUOTA=200000
COUNTRY_DAILY_QUOTA=50000

LOG_LEVEL=info
OTEL_ENABLED=false
OTEL_SERVICE_NAME=sms-sending-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

QUEUE_WORKER_ENABLED=true
QUEUE_SMS_ATTEMPTS=8
QUEUE_SMS_BACKOFF_MS=5000
QUEUE_WEBHOOK_ATTEMPTS=10
QUEUE_WEBHOOK_BACKOFF_MS=3000

CORS_ORIGINS=https://app.example.com

NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sms_api

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_COMMAND_TIMEOUT_MS=5000

JWT_SECRET=change_me_to_32_plus_chars_secret_value
JWT_ISSUER=sms-api
JWT_AUDIENCE=sms-clients
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
JWT_KEY_ID=primary-v1
JWT_PUBLIC_KEY=

API_KEY_HASH_SECRET=change_me_to_32_plus_chars_secret_value
API_KEY_PREFIX=sms_live_
SMS_PROVIDER=mock

CLICK_MERCHANT_ID=click_merchant_id
CLICK_SECRET_KEY=click_secret
PAYME_MERCHANT_ID=payme_merchant_id
PAYME_SECRET_KEY=payme_secret
PAYMENT_RETURN_URL=https://your-app.example/payments/return

WEBHOOK_MAX_DRIFT_SECONDS=300
WEBHOOK_NONCE_TTL_SECONDS=3600
DEFAULT_DAILY_SPEND_LIMIT=500
ALLOWED_SMS_COUNTRIES=UZ,US,GB

PROMETHEUS_ENABLED=true
OTEL_SERVICE_NAME=sms-sending-api
OTEL_EXPORTER_OTLP_ENDPOINT=

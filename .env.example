NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sms_api

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_COMMAND_TIMEOUT_MS=5000

JWT_SECRET=change_me
JWT_PREVIOUS_SECRETS=
JWT_KEY_ID=primary
JWT_ISSUER=sms-saas
JWT_AUDIENCE=sms-api
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

API_KEY_HASH_SECRET=change_me
SMS_PROVIDER=mock

CLICK_MERCHANT_ID=your_click_service_id
CLICK_SECRET_KEY=your_click_secret
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_SECRET_KEY=your_payme_secret

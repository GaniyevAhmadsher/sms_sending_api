NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sms_api?schema=public
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_COMMAND_TIMEOUT_MS=2000

LOG_LEVEL=info

JWT_SECRET=replace_with_32+_chars_secret
JWT_ISSUER=sms-saas-api
JWT_AUDIENCE=sms-saas-clients
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

API_KEY_HASH_SECRET=replace_with_32+_chars_secret
SMS_PROVIDER=mock

CLICK_MERCHANT_ID=your_click_merchant_id
CLICK_SECRET_KEY=your_click_secret
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_SECRET_KEY=your_payme_secret
PAYMENT_RETURN_URL=https://app.example.com/payments/return

WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
WEBHOOK_NONCE_TTL_SECONDS=900

QUEUE_WORKER_ENABLED=false

{
  "title": "SMS Platform Overview",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {"type":"timeseries","title":"SMS Sent","targets":[{"expr":"rate(sms_send_total[5m])"}]},
    {"type":"timeseries","title":"SMS Success","targets":[{"expr":"rate(sms_success_total[5m])"}]},
    {"type":"timeseries","title":"SMS Failed","targets":[{"expr":"rate(sms_failed_total[5m])"}]},
    {"type":"timeseries","title":"API p95 Duration","targets":[{"expr":"histogram_quantile(0.95, sum by (le) (rate(api_request_duration_bucket[5m])))"}]},
    {"type":"timeseries","title":"Queue Depth","targets":[{"expr":"queue_depth"}]}
  ]
}
